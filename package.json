{
  "name": "rust-lint-action",
  "version": "2.3.0",
  "private": true,
  "description": "GitHub Action for detecting and fixing linting errors for rust",
  "license": "MIT",
  "repository": "github:wearerequired/lint-action",
  "main": "./dist/index.js",
  "scripts": {
    "test": "jest",
    "lint": "eslint --max-warnings 0 \"**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "oxfmt",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "command-exists": "^1.2.9",
    "parse-diff": "^0.11.1"
  },
  "devDependencies": {
    "@types/command-exists": "^1.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "oxfmt": "^0.45.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "jest": {
    "preset": "ts-jest",
    "setupFilesAfterEnv": [
      "./test/mock-actions-core.ts"
    ],
    "testEnvironment": "node"
  }
}
