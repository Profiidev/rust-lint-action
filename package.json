{
  "name": "rust-lint-action",
  "version": "4.2.0",
  "private": true,
  "description": "GitHub Action for detecting and fixing linting errors for rust",
  "license": "MIT",
  "repository": "github:wearerequired/lint-action",
  "main": "./dist/index.js",
  "scripts": {
    "build": "vite build",
    "lint": "eslint --max-warnings 0 \"**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "oxfmt",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@octokit/core": "^7.0.6",
    "command-exists": "^1.2.9",
    "parse-diff": "^0.12.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.98.1",
    "@redocly/cli": "^2.31.5",
    "@types/command-exists": "1.2.3",
    "@types/node": "25.9.1",
    "openapi-format": "^1.32.1",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
