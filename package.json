{
  "name": "rust-lint-action",
  "version": "4.1.0",
  "private": true,
  "description": "GitHub Action for detecting and fixing linting errors for rust",
  "license": "MIT",
  "repository": "github:wearerequired/lint-action",
  "main": "./dist/index.js",
  "scripts": {
    "build": "vite build",
    "lint": "eslint --max-warnings 0 \"**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "oxfmt",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@octokit/core": "^7.0.6",
    "command-exists": "^1.2.9",
    "parse-diff": "^0.11.1"
  },
  "devDependencies": {
    "@types/command-exists": "1.2.3",
    "@types/node": "25.6.0",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.1",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  }
}
